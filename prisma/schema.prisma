generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

// ----- AUTH MODELS -----
model User {
  // Primary Key
  id            String       @id
  // Other fields
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  // Relationships
  sessions      Session[]
  accounts      Account[]
  profile       ProfileUser?

  // Other things
  @@unique([email])
  @@map("user")
  @@schema("auth")
}

model Session {
  // Foreign Key
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Primary Key
  id        String   @id
  // Other fields
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  // Other things
  @@unique([token])
  @@index([userId])
  @@map("session")
  @@schema("auth")
}

model Account {
  // Foreign Key
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Primary Key
  id                    String    @id
  // Other fields
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Other things
  @@index([userId])
  @@map("account")
  @@schema("auth")
}

model Verification {
  // Primary Key
  id         String   @id
  // Other fields
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Other things
  @@index([identifier])
  @@map("verification")
  @@schema("auth")
}

// ----- PROFILE MODELS -----
model ProfileUser {
  // Foreign Key
  userId            String            @unique @map("user_id")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Primary Key
  profileId         String            @id @map("profile_id")
  // Other fields
  profileLastName   String            @map("profile_last_name")
  profileFirstName  String            @map("profile_first_name")
  profileMiddleName String?           @map("profile_middle_name")
  profileSuffix     String?           @map("profile_suffix")
  profileRole       String            @map("profile_role")
  // Relationships
  personal          ProfilePersonal[]

  //Other things
  @@map("profile_user")
  @@schema("public")
}

model ProfilePersonal {
  // Foreign Key
  profileId              String      @unique @map("profile_id")
  profile                ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  personalId             String      @id @map("personal_id")
  // Other fields
  profileBirthdate       DateTime?   @map("profile_birthdate") @db.Date
  profileAge             Int?        @map("profile_age")
  profilePlaceOfBirth    String?     @map("profile_place_of_birth")
  profileSex             String?     @map("profile_sex")
  profileHeight          Int?        @map("profile_height")
  profileCivilStatus     String?     @map("profile_civil_status")
  profileLanguageDialect Json?       @map("profile_language_dialect")
  profileContact         String?     @map("profile_contact")
  profileFacebook        String?     @map("profile_facebook")

  //Other things
  @@map("profile_personal")
  @@schema("public")
}

