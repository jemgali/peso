generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

// ----- AUTH MODELS -----

model User {
  // Primary Key
  id            String       @id
  // Other fields
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  role          String?
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  // Relationships
  sessions      Session[]
  accounts      Account[]
  profile       ProfileUser?
  reviews       ApplicationReview[]
  notifications Notification[]

  // Other things
  @@unique([email])
  @@map("user")
  @@schema("auth")
}

model Session {
  // Foreign Key
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Primary Key
  id             String   @id
  // Other fields
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?

  // Other things
  @@unique([token])
  @@index([userId])
  @@map("session")
  @@schema("auth")
}

model Account {
  // Foreign Key
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Primary Key
  id                    String    @id
  // Other fields
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Other things
  @@index([userId])
  @@map("account")
  @@schema("auth")
}

model Verification {
  // Primary Key
  id         String   @id
  // Other fields
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Other things
  @@index([identifier])
  @@map("verification")
  @@schema("auth")
}

// ----- PROFILE MODELS -----

// SPES Applicant Name + Role
model ProfileUser {
  // Foreign Key
  userId            String             @unique @map("user_id")
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Primary Key
  profileId         String             @id @map("profile_id")
  // Other fields
  profileLastName   String?            @map("profile_last_name")
  profileFirstName  String?            @map("profile_first_name")
  profileMiddleName String?            @map("profile_middle_name")
  profileSuffix     String?            @map("profile_suffix")
  profileEmail      String?            @map("profile_email")
  // Relationships
  personal          ProfilePersonal?
  address           ProfileAddress?
  family            ProfileFamily?
  guardian          ProfileGuardian?
  benefactor        ProfileBenefactor?
  education         ProfileEducation?
  skills            ProfileSkills?
  documents         ProfileDocuments?
  spes              ProfileSPES?
  submissions       ApplicationSubmission[]

  @@map("profile_user")
  @@schema("public")
}

// SPES Applicant Personal Information (birth, sex, height, civil status, religion, language, contact, disability)
model ProfilePersonal {
  // Foreign Key
  profileId              String      @unique @map("profile_id")
  profile                ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  personalId             String      @id @map("personal_id")
  // Birth information
  profileBirthdate       DateTime?   @map("profile_birthdate") @db.Date
  profileAge             Int?        @map("profile_age")
  profilePlaceOfBirth    String?     @map("profile_place_of_birth")
  // Personal information
  profileSex             String?     @map("profile_sex")
  profileHeight          Int?        @map("profile_height")
  profileCivilStatus     String?     @map("profile_civil_status")
  profileReligion        String?     @map("profile_religion")
  profileLanguageDialect Json?       @map("profile_language_dialect")

  profileContact         String?     @map("profile_contact")
  profileFacebook        String?     @map("profile_facebook")
  // Disability (if applicable)
  profileDisability      String?     @map("profile_disability")
  profilePwdId           String?     @map("profile_pwd_id")

  @@map("profile_personal")
  @@schema("public")
}

// SPES Applicant Address
model ProfileAddress {
  // Foreign Key
  profileId           String      @unique @map("profile_id")
  profile             ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  addressId           String      @id @map("address_id")
  // Other fields
  profileHouseStreet  String?     @map("profile_house_street")
  profileBarangay     String?     @map("profile_barangay")
  profileMunicipality String?     @map("profile_municipality")
  profileProvince     String?     @map("profile_province")

  @@map("profile_address")
  @@schema("public")
}

// SPES Applicant Family Information (father, mother, siblings)
model ProfileFamily {
  // Foreign Key
  profileId        String      @unique @map("profile_id")
  profile          ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  familyId         String      @id @map("family_id")
  // Father information
  fatherName       String?     @map("father_name")
  fatherOccupation String?     @map("father_occupation")
  fatherContact    String?     @map("father_contact")
  // Mother information
  motherMaidenName String?     @map("mother_maiden_name")
  motherOccupation String?     @map("mother_occupation")
  motherContact    String?     @map("mother_contact")
  // Siblings information
  numberOfSiblings Int?        @map("number_of_siblings")
  // siblings: [{ name: String, age: Int?, sex: String? }, ...]
  siblings         Json?       @map("siblings")

  @@map("profile_family")
  @@schema("public")
}

// SPES Applicant Guardian Information
model ProfileGuardian {
  // Foreign Key
  profileId            String      @unique @map("profile_id")
  profile              ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  guardianId           String      @id @map("guardian_id")
  // Other fields
  guardianName         String?     @map("guardian_name")
  guardianContact      String?     @map("guardian_contact")
  guardianAddress      String?     @map("guardian_address")
  guardianAge          Int?        @map("guardian_age")
  guardianOccupation   String?     @map("guardian_occupation")
  guardianRelationship String?     @map("guardian_relationship")

  @@map("profile_guardian")
  @@schema("public")
}

// SPES Applicant Benefactor Information (if applicable)
model ProfileBenefactor {
  // Foreign Key
  profileId              String      @unique @map("profile_id")
  profile                ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  benefactorId           String      @id @map("benefactor_id")
  // Other fields
  benefactorName         String?     @map("benefactor_name")
  benefactorRelationship String?     @map("benefactor_relationship")

  @@map("profile_benefactor")
  @@schema("public")
}

// SPES Applicant Education
model ProfileEducation {
  // Foreign Key
  profileId   String      @unique @map("profile_id")
  profile     ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  educationId String      @id @map("education_id")
  // Other fields
  gradeYear   String?     @map("grade_year")
  schoolName  String?     @map("school_name")
  trackCourse String?     @map("track_course")
  schoolYear  String?     @map("school_year")

  @@map("profile_education")
  @@schema("public")
}

// SPES Applicant Skills
model ProfileSkills {
  // Foreign Key
  profileId String      @unique @map("profile_id")
  profile   ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  skillsId  String      @id @map("skills_id")
  // Other fields
  // skills: ["skill1", "skill2", ...]
  skills    Json?       @map("skills")

  @@map("profile_skills")
  @@schema("public")
}

// SPES Applicant Documents (PSA Certificate, Grades, Affidavits, Death Certificate, Income Tax Return, etc.)
model ProfileDocuments {
  // Foreign Key
  profileId  String      @unique @map("profile_id")
  profile    ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  documentId String      @id @map("document_id")
  // Other fields (stored as JSON for flexibility)
  // documents: { [documentType: string]: { url: String, uploadDate: DateTime, verified: Boolean } }
  // e.g., "psaCertificate", "grades", "affidavit", "deathCertificate", "incomeTaxReturn"
  documents  Json?       @map("documents")

  @@map("profile_documents")
  @@schema("public")
}

// SPES-Specific Information (4Ps beneficiary, application year, motivation, remarks)
model ProfileSPES {
  // Foreign Key
  profileId           String      @unique @map("profile_id")
  profile             ProfileUser @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  spesId              String      @id @map("spes_id")
  // Other fields
  isFourPsBeneficiary Boolean?    @map("is_four_ps_beneficiary")
  applicationYear     Int?        @map("application_year")
  spesBabiesAvailmentYears Int?   @map("spes_babies_availment_years")
  motivation          String?     @map("motivation")
  remarks             String?     @map("remarks")

  @@map("profile_spes")
  @@schema("public")
}

// ----- APPLICATION REVIEW MODELS -----

// Application submission status enum values: pending, in_review, approved, needs_revision, rejected
model ApplicationSubmission {
  // Foreign Key
  profileId       String              @map("profile_id")
  profile         ProfileUser         @relation(fields: [profileId], references: [profileId], onDelete: Cascade)
  // Primary Key
  submissionId    String              @id @map("submission_id")
  // Status fields
  status          String              @default("pending") @map("status") // pending, in_review, approved, needs_revision, rejected
  submissionNumber Int                @default(1) @map("submission_number") // Track resubmission count
  // Timestamps
  submittedAt     DateTime            @default(now()) @map("submitted_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  // Relationships
  reviews         ApplicationReview[]

  @@index([profileId])
  @@index([status])
  @@map("application_submission")
  @@schema("public")
}

// Application review by admin
model ApplicationReview {
  // Foreign Key - Submission being reviewed
  submissionId          String                   @map("submission_id")
  submission            ApplicationSubmission    @relation(fields: [submissionId], references: [submissionId], onDelete: Cascade)
  // Foreign Key - Admin who reviewed
  reviewerId            String                   @map("reviewer_id")
  reviewer              User                     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  // Primary Key
  reviewId              String                   @id @map("review_id")
  // Review decision
  decision              String                   @map("decision") // approved, needs_revision, rejected
  overallComments       String?                  @map("overall_comments")
  // Timestamps
  reviewedAt            DateTime                 @default(now()) @map("reviewed_at")
  // Relationships
  fieldFeedback         ReviewFieldFeedback[]
  documentFeedback      ReviewDocumentFeedback[]

  @@index([submissionId])
  @@index([reviewerId])
  @@map("application_review")
  @@schema("public")
}

// Per-field feedback from admin review
model ReviewFieldFeedback {
  // Foreign Key
  reviewId    String            @map("review_id")
  review      ApplicationReview @relation(fields: [reviewId], references: [reviewId], onDelete: Cascade)
  // Primary Key
  feedbackId  String            @id @map("feedback_id")
  // Field identification
  sectionId   String            @map("section_id") // e.g., "basic-info", "personal-details"
  fieldName   String            @map("field_name") // e.g., "profileLastName", "profileBirthdate"
  // Feedback
  status      String            @map("status") // valid, invalid
  comment     String?           @map("comment")

  @@index([reviewId])
  @@map("review_field_feedback")
  @@schema("public")
}

// Per-document verification from admin review
model ReviewDocumentFeedback {
  // Foreign Key
  reviewId     String            @map("review_id")
  review       ApplicationReview @relation(fields: [reviewId], references: [reviewId], onDelete: Cascade)
  // Primary Key
  feedbackId   String            @id @map("feedback_id")
  // Document identification
  documentType String            @map("document_type") // e.g., "psaCertificate", "schoolId", "grades"
  // Verification status
  status       String            @map("status") // valid, invalid, missing
  comment      String?           @map("comment")

  @@index([reviewId])
  @@map("review_document_feedback")
  @@schema("public")
}

// In-app notifications
model Notification {
  // Foreign Key - User receiving notification
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Primary Key
  notificationId String   @id @map("notification_id")
  // Notification content
  type          String    @map("type") // application_approved, application_revision, application_rejected
  title         String    @map("title")
  message       String    @map("message")
  link          String?   @map("link") // Optional link to related page
  // Status
  isRead        Boolean   @default(false) @map("is_read")
  // Timestamps
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notification")
  @@schema("public")
}

// ----- PROGRAM MODELS -----

// PESO Programs (GIP, SPES, NSRP, DILP, Jobstart, TUPAD, etc.)
model Program {
  // Primary Key
  id          String   @id @default(cuid())
  // Program details
  title       String
  description String?
  image       String?  // URL to program logo/image
  link        String?  // URL to program details page
  // Status and ordering
  status      String   @default("active") // active, inactive
  order       Int      @default(0) // Display order
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("program")
  @@schema("public")
}

// ----- SCHEDULE MODELS -----

// Schedule events (announcements, deadlines, schedules)
model ScheduleEvent {
  // Primary Key
  id          String    @id @default(cuid())
  // Event details
  title       String
  description String?
  type        String    // announcement, schedule, deadline
  visibility  String    @default("all") // all, clients, employees
  // Date/Time
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  allDay      Boolean   @default(false) @map("all_day")
  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([startDate])
  @@index([type])
  @@map("schedule_event")
  @@schema("public")
}
